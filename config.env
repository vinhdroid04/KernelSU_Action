# ==================== KERNEL SOURCE ====================
Kernel_Source=https://github.com/LineageOS/android_kernel_xiaomi_sdm710
Kernel_Source_Branch=lineage-20

# ==================== KERNEL CONFIG ====================
Kernel_Config=sdm710_defconfig
Arch=arm64
Kernel_Image_Name=Image.gz-dtb

# ==================== COMPILER - CUSTOM CLANG (FIX 404) ====================
Use_custom_clang=true
Custom_Clang_Source=https://github.com/kdrag0n/proton-clang
Custom_Clang_Branch=master

Enable_GCC_64=true
Enable_GCC_32=true

# ==================== KERNELSU ====================
Enable_KernelSU=true
KernelSU_Branch_or_Tag=v0.9.5

# ==================== FIX CHO KERNEL 4.9 ====================
Add_Kprobes_Config=true
Add_overlayfs_Config=true
Apply_KernelSU_Patch=true
Disable_CC_WERROR=true
Disable_LTO=true
Disable_WERROR=true

# ==================== ANYKERNEL3 ====================
Use_custom_AnyKernel3=false

# ==================== KHÁC ====================
Enable_ccache=true
Build_Boot_IMG=false
Clean_Before_Build=true
