# ==================== KERNEL SOURCE ====================
Kernel_Source=https://github.com/LineageOS/android_kernel_xiaomi_sdm710
Kernel_Source_Branch=lineage-20

# ==================== KERNEL CONFIG ====================
Kernel_Config=sdm710_defconfig          # defconfig phổ biến cho sirius/sdm710
Arch=arm64
Kernel_Image_Name=Image.gz-dtb

# ==================== COMPILER ====================
Use_custom_clang=false                  # Dùng clang mặc định của action
Clang_version=r450784d                  # Android T - phù hợp kernel 4.9
Enable_GCC_64=true
Enable_GCC_32=true

# ==================== KERNELSU ====================
Enable_KernelSU=true
KernelSU_Branch_or_Tag=v0.9.5          # BẮT BUỘC dùng v0.9.5 cho kernel 4.9

# ==================== CẤU HÌNH BỔ SUNG (quan trọng cho 4.9) ====================
Add_Kprobes_Config=true
Add_overlayfs_Config=true
Apply_KernelSU_Patch=true               # Tự động áp patch path_umount + ksud fix
Disable_CC_WERROR=true                  # Tránh lỗi warning trên kernel cũ
Disable_LTO=true                        # Giảm lỗi build

# ==================== ANYKERNEL3 ====================
Use_custom_AnyKernel3=false             # Dùng AnyKernel3 mặc định (đã tắt check device)
# Nếu muốn custom (khuyến nghị sau khi build lần 1):
# Use_custom_AnyKernel3=true
# Custom_AnyKernel3_Source=https://github.com/TÊN_BẠN/AnyKernel3.git
# AnyKernel3_Branch=master

# ==================== KHÁC ====================
Enable_ccache=true
Build_Boot_IMG=false                    # Chỉ cần ZIP là đủ
